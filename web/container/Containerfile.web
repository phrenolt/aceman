# Aceman web frontend — rootless podman container.
#
# Sibling to engine/container/Containerfile (which sandboxes the untrusted
# acestream engine). This image is for OUR code: the Python web
# frontend that the user actually browses. Reason to containerize it
# even though it's our own code:
#   * Distribution — ship one image, no host python install needed.
#   * No host ffmpeg dependency — the in-browser stream proxy spawns
#     ffmpeg via subprocess; bundling it removes a setup step.
#   * Same blast-radius story as the engine: a hypothetical bug in
#     our stream proxy or HTTP server can't reach host files outside
#     the explicit volume mounts.
#
# Broker stays on the host. It needs podman (which means access to
# the user's podman socket / fork-exec rights), file-system access to
# write the desktop entry, and the ability to spawn the shell
# `aceman` wrapper for player launch. None of that survives a
# container boundary without weakening it pointlessly. The web in the
# container talks to the host broker over the UNIX socket at
# $XDG_RUNTIME_DIR/aceman/broker.sock, which is mounted in.

FROM docker.io/library/python:3.11-slim-bookworm

# ffmpeg is what the web exec()s to transcode. vainfo is here for the
# broker's VA-API probe: the broker runs `podman exec <web> vainfo` so the
# GPU capability is read from the driver THIS image carries, not the host's
# (Fedora ships a codec-stripped iHD on the host that hides H.264 encode).
# --no-install-recommends keeps the image lean (no docs / X libs).
# rm -rf /var/lib/apt/lists shaves another ~40 MB.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       ffmpeg \
       mesa-va-drivers libva-drm2 mesa-vulkan-drivers \
       intel-media-va-driver i965-va-driver \
       vainfo \
       curl \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /usr/local/share/aceman/shaders \
    && (curl -fsSL -o /usr/local/share/aceman/shaders/FSRCNNX_x2_16-0-4-1.glsl \
        https://raw.githubusercontent.com/bjin/mpv-prescalers/master/FSRCNNX_x2_16-0-4-1.glsl \
        && echo "FSRCNNX shader downloaded" \
        || echo "Warning: FSRCNNX shader download failed — ewa_lanczos fallback active")

WORKDIR /app

# Project root is the build context. We only need web/, the mpegts.js
# vendor bundle and the HTML/CSS sit under web/. Broker code stays on
# the host so we don't ship it inside this image.
COPY web /app/web

# Per project convention: stdlib-only Python. No requirements.txt /
# pip install step.

# Build identity, baked at build time so the in-page `dbg` overlay can
# report which commit this image was built from — independent of how the
# container is later launched (wrapper `podman run` OR a broker recreate
# that replays config, which a runtime -e would NOT survive). Supplied by
# lib.sh's _ensure_podman_image. Placed AFTER the heavy apt/COPY layers so
# a commit change only rebuilds this cheap trailing layer. Empty / 0
# outside a git checkout.
ARG ACEMAN_COMMIT=
ARG ACEMAN_DIRTY=0
ENV ACEMAN_COMMIT=${ACEMAN_COMMIT} \
    ACEMAN_DIRTY=${ACEMAN_DIRTY}

# Default port — overridable from the launcher's --port flag.
EXPOSE 8770

# The launcher passes a full argv (--host / --port / --engine /
# --broker-socket / etc.); CMD is just a sane fallback for a bare
# `podman run` without args. Bind 0.0.0.0 so the host's port forward
# can reach us.
CMD ["python3", "web/aceman_web.py", "--host", "0.0.0.0", "--port", "8770"]
