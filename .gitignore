# Engine binary — proprietary Ace Stream tarball; users fetch it
# themselves from https://docs.acestream.net/products/#linux (Linux →
# Ubuntu amd64 / py3.10 build). Keeping it out of git avoids
# redistributing proprietary software and keeps the repo small; the
# .sha256 sibling stays so users can verify their download.
engine/container/dist/engine.tar.gz

# Claude Code tooling state (per-clone, not source).
.claude/
CLAUDE.md
claude resume*.txt

# Generated by web/ui/tools/check_bundle.sh — the assembled real-bundle
# smoke artefact, rewritten on each run.
web/ui/tools/.bundle_check.mjs

# Python bytecode / build artefacts.
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Editor / OS junk.
*.swp
*.swo
.DS_Store
Thumbs.db

# Local logs (the project writes these under ~/.cache/aceman by
# default; this is just a safety net if a user runs from this dir).
*.log
